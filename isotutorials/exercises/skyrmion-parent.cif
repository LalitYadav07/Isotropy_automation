9 y,x,-z
10 -x+y,y,-z
11 -x,-x+y,-z
12 -y,-x,-z
13 -x,-y,-z
14 -x+y,-x,-z
15 y,-x+y,-z
16 x,y,-z
17 x-y,x,-z
18 -y,x-y,-z
19 -x+y,y,z
20 -x,-x+y,z
21 -y,-x,z
22 x-y,-y,z
23 x,x-y,z
24 y,x,z

loop_
_atom_site_label
_atom_site_type_symbol
_atom_site_symmetry_multiplicity
