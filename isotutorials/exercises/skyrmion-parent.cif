# Triangular Fe layer -- skyrmion parent structure

data_isocif-output
_audit_creation_method ISOCIF

_cell_length_a     2.71500
_cell_length_b     2.71500
_cell_length_c     6.00000
_cell_angle_alpha  90.00000
_cell_angle_beta   90.00000
_cell_angle_gamma  120.00000
_cell_volume       38.30201

_symmetry_space_group_name_H-M "P 6/m 2/m 2/m"
_symmetry_Int_Tables_number 191
_space_group.reference_setting '191:-P 6 2'
_space_group.transform_Pp_abc a,b,c;0,0,0

